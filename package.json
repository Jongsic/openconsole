{
  "name": "openconsole",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "Unlicense",
  "description": "OpenConsole — a browser-only console for LocalStack, MinIO, and AWS",
  "keywords": [
    "s3",
    "aws",
    "localstack",
    "minio",
    "s3-browser",
    "s3-console",
    "browser-only",
    "static-site",
    "react",
    "vite"
  ],
  "homepage": "https://jongsic.github.io/openconsole/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jongsic/openconsole.git"
  },
  "bugs": {
    "url": "https://github.com/Jongsic/openconsole/issues"
  },
  "author": "Jongsic",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --port 3939",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 3939",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@aws-sdk/client-auto-scaling": "^3.1073.0",
    "@aws-sdk/client-ec2": "^3.1072.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1073.0",
    "@aws-sdk/client-elasticache": "^3.1073.0",
    "@aws-sdk/client-iam": "^3.1073.0",
    "@aws-sdk/client-lambda": "^3.1073.0",
    "@aws-sdk/client-rds": "^3.1073.0",
    "@aws-sdk/client-s3": "^3.1073.0",
    "@aws-sdk/s3-request-presigner": "^3.1073.0",
    "@tanstack/react-query": "^5.101.0",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.577.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^15.7.4",
    "react-router-dom": "^6.30.4",
    "tailwind-merge": "^2.6.1",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "aws-sdk-client-mock": "^4.1.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
