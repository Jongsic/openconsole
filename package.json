{
  "name": "openconsole",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "Unlicense",
  "description": "OpenConsole — a browser-only console for LocalStack, MinIO, and AWS",
  "keywords": [
    "s3",
    "aws",
    "localstack",
    "minio",
    "s3-browser",
    "s3-console",
    "browser-only",
    "static-site",
    "react",
    "vite"
  ],
  "homepage": "https://jongsic.github.io/openconsole/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jongsic/openconsole.git"
  },
  "bugs": {
    "url": "https://github.com/Jongsic/openconsole/issues"
  },
  "author": "Jongsic",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --port 3939",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 3939",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@aws-sdk/s3-request-presigner": "^3.637.0",
    "@tanstack/react-query": "^5.51.0",
    "clsx": "^2.1.1",
    "i18next": "^23.12.2",
    "i18next-browser-languagedetector": "^8.0.0",
    "lucide-react": "^0.427.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^6.26.0",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.4.5",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
